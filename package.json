{
  "name": "sensa-chrome-extension",
  "displayName": "Sensa chrome extension",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Sensa",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-transition-group": "^4.4.5",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "tabCapture",
      "activeTab",
      "offscreen"
    ],
    "host_permissions": [
      "https://*/*",
      "https://*.youtube.com/*",
      "<all_urls>"
    ]
  }
}
